# 复制为 .env 并填入你的真实值： cp .env.example .env
# ============ 必填 ============
DEEPSEEK_API_KEY=sk-请填入你的DeepSeek密钥

# ============ 模型（重要）============
# 请填 DeepSeek 官方文档中“V4 Pro”对应的模型 ID。
# 若暂不确定，deepseek-chat 是指向最新通用对话模型的别名，可先用它兜底。
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============ 可选调参 ============
# DEEPSEEK_MAX_TOKENS=8192      # 单次最大输出 token
# DEEPSEEK_TIMEOUT=600          # 单次请求超时(秒)
# DEEPSEEK_MAX_RETRIES=5        # 失败重试次数
# CLEAN_CHUNK_CHARS=3500        # 阶段一每个清洗块的目标字符数
# COURSE_NAME=中国经济思想史        # 课程名（用于文件命名与提示词）
# TEMP_CLEAN=0.2                # 清洗温度（越低越忠实）
# TEMP_NOTES=0.4
# TEMP_CONCEPTS=0.35
# TEMP_INDEX=0.3
